# Production / Vercel / static host — set in the host’s Environment Variables UI.
# Values are baked in at `npm run build` time (Vite).

# Public API origin (no trailing slash). Required whenever the SPA is NOT served
# from the same host as the API (e.g. Vercel app + Render API).
# Example: https://paropakar-vendornet-api.onrender.com
VITE_API_BASE_URL=https://your-api.example.com
