# Copy to .env.local for local overrides. Never commit real production URLs with secrets.

# --- Local dev (default)
# `npm run dev` proxies /api → the API origin from ../backend/.env (BACKEND_URL or PORT). You usually do NOT need VITE_API_BASE_URL locally.
# Only if backend/.env is missing, you may set (must match the real API port):
# VITE_PROXY_TARGET=http://127.0.0.1:5001

# --- Vercel / production (REQUIRED for deployed frontend)
# Public API origin only — no trailing slash. Browser calls ${VITE_API_BASE_URL}/api/...
# Create in Vercel: Project → Settings → Environment Variables (Production + Preview as needed).
# VITE_API_BASE_URL=https://your-api.onrender.com

# Optional: eSewa return URLs or absolute backend links in dev
# VITE_BACKEND_PUBLIC_URL=http://127.0.0.1:5000
