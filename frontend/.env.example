# =============================================================================
# Local development (optional file: .env.development)
# =============================================================================
# Vite proxies /api to your backend. Default: reads PORT from ../backend/.env
# VITE_PROXY_TARGET=http://127.0.0.1:5000

# Used for eSewa form return URLs in dev if needed. Defaults to VITE_PROXY_TARGET.
# VITE_BACKEND_PUBLIC_URL=http://127.0.0.1:5000

# =============================================================================
# Production (Vercel) — REQUIRED or login/API will show "Network Error"
# =============================================================================
# Set this in Vercel → Project → Settings → Environment Variables (Production).
# Must be your public Render API URL, no trailing slash.
# Example: VITE_API_BASE_URL=https://your-service.onrender.com
#
# Without VITE_API_BASE_URL, the browser calls /api/... on the Vercel hostname,
# where there is no API — all authenticated requests fail.
# VITE_API_BASE_URL=

# If you use Vercel preview deployments, either:
# - add a second preview env var pointing at staging API, or
# - use the same production API URL for Preview (not ideal for data isolation)
