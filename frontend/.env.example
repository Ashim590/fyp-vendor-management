# Copy to `.env.local` for machine-specific overrides. Commit only `.env.example` / `.env.production.example`.

# --- Local dev
# `npm run dev` proxies `/api` to the origin read from `../backend/.env` (PORT / BACKEND_URL).
# You normally leave VITE_API_BASE_URL unset so requests stay relative and hit the proxy.
# VITE_PROXY_TARGET=http://127.0.0.1:5001

# --- Deployed frontend (Vercel / Netlify / etc.)
# Copy `frontend/.env.production.example` into your host’s Production env vars.
# VITE_API_BASE_URL=https://your-api.onrender.com

# Optional dev-only absolute backend (match your local API port)
# VITE_BACKEND_PUBLIC_URL=http://127.0.0.1:5001
