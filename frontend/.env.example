# Copy to .env.development for local dev (recommended).
# MUST match Express PORT in backend/.env (same host/port the API listens on).
VITE_PROXY_TARGET=http://127.0.0.1:5000

# Absolute API origin for eSewa return URLs (su/fu) on the HTML form. Defaults to VITE_PROXY_TARGET.
# VITE_BACKEND_PUBLIC_URL=http://127.0.0.1:5000

# Production build: set to your public API origin (no trailing slash), e.g. https://api.example.com
# Leave unset if the SPA is served from the same origin as the API or reverse-proxies /api.
# VITE_API_BASE_URL=https://api.example.com
