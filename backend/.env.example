# Copy to .env for local dev. Don't commit real secrets.

# On some macOS versions, port 5000 is used by AirPlay (Control Center) — use 5001 if bind fails.
PORT=5000
NODE_ENV=development

# Mongo — local or Atlas (mongodb+srv://...)
# REQUIRED in production — server will not start without it.
MONGO_URI=mongodb://localhost:27017/paropakar_vendornet

# Signing tokens. REQUIRED in production (server exits if empty).
JWT_SECRET=replace_with_long_random_string

# Access token lifetime (jsonwebtoken `expiresIn`, e.g. 8h, 7d). Default 8h if unset.
# JWT_EXPIRES_IN=8h

# Who can call the API from a browser. Comma-separated, exact URL (scheme + host).
# Add every frontend URL you use or you'll get CORS headaches.
# Vercel: include https://your-app.vercel.app and any custom domain.
CLIENT_ORIGINS=http://localhost:5173

# Used for payment redirects and similar. Match what you actually run.
# Render/Railway: https://your-api.onrender.com (no trailing slash)
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Optional: all /api requests per IP per 15 minutes (default 400 in production, 0=disabled in dev)
# API_GLOBAL_RATE_LIMIT_MAX=400

# Optional: serve Vite dist from this Node app (single-service deploy). Path to folder with index.html.
# CLIENT_DIST_PATH=../frontend/dist

# NEVER enable on public production unless you understand the risk (exposes bootstrap admin).
# ALLOW_BOOTSTRAP_ADMIN=false

# --- Production-ish / deploy (usually set in Render, not in a committed file)
#
# NODE_ENV=production
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/DATABASE?retryWrites=true&w=majority
# JWT_SECRET=<run: openssl rand -hex 64>
# CLIENT_ORIGINS=https://app.vercel.app,https://yourdomain.com
# BACKEND_URL=https://xxx.onrender.com
# FRONTEND_URL=https://app.vercel.app
# (Render often sets PORT for you; you can leave PORT out.)

# Cloudinary — only if you use uploads through them
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# eSewa — see https://developer.esewa.com.np/pages/Epay-V2
# Verbose status logging (default off in production)
# ESEWA_DEBUG=1
# ESEWA_MODE=sandbox
# ESEWA_PRODUCT_CODE=
# ESEWA_SECRET_KEY=
# ESEWA_SANDBOX_CHECKOUT_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
# ESEWA_PROD_CHECKOUT_URL=https://epay.esewa.com.np/api/epay/main/v2/form
# ESEWA_UAT_STATUS_URL_BASE=https://rc.esewa.com.np/api/epay/transaction/status/
# ESEWA_PROD_STATUS_URL_BASE=https://epay.esewa.com.np/api/epay/transaction/status/
#
# Invoice flow defaults to BACKEND_URL / FRONTEND_URL if you skip these:
# ESEWA_SUCCESS_URL=${BACKEND_URL}/api/v1/invoice-payment/esewa/success
# ESEWA_FAILURE_URL=${BACKEND_URL}/api/v1/invoice-payment/esewa/failure
# CLIENT_ESEWA_SUCCESS_RETURN_URL=${FRONTEND_URL}/payments/esewa/success
# CLIENT_ESEWA_FAILURE_RETURN_URL=${FRONTEND_URL}/payments/esewa/failure
#
# Tender payment callback — app appends /:paymentId
# ESEWA_TENDER_SUCCESS_URL=${BACKEND_URL}/api/v1/payment/esewa/callback
# ESEWA_TENDER_FAILURE_URL=${FRONTEND_URL}/my-payments?paymentStatus=cancelled

# Dashboard caches (milliseconds). Bigger = fewer DB hits, staler numbers.
# ADMIN_DASHBOARD_CACHE_MS=120000
# STAFF_DASHBOARD_CACHE_MS=60000

# Caps this month's spend on the staff dashboard (NPR). Payments counted: completed tender + paid invoice, current month.
# PROCUREMENT_MONTHLY_BUDGET_NPR=500000

# NOTIFICATION_LIST_CACHE_MS=30000

# Max allowed GPS accuracy (meters) for delivery receipt confirmation.
# Lower = stricter audit evidence.
# DELIVERY_CONFIRM_MAX_ACCURACY_METERS=50

# Email copy of in-app notifications (optional). Needs SMTP_HOST and SMTP_FROM.
# NOTIFICATION_EMAIL=0
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.org
# MAIL_FROM_NAME=Paropakar VendorNet

# Verbose invoice auto-create logs (default off in production; set to 1 to debug).
# INVOICE_DEBUG=1

# Debug / perf (API_PERF_LOG is ignored in production unless API_PERF_IN_PRODUCTION=1)
# API_PERF_LOG=1
# API_PERF_IN_PRODUCTION=1
# API_SLOW_REQUEST_MS=2000
