# =============================================================================
# Local development — copy to .env and adjust (never commit real .env)
# =============================================================================
PORT=5000
NODE_ENV=development

# Database (Atlas: use mongodb+srv://... ; never commit credentials)
MONGO_URI=mongodb://localhost:27017/paropakar_vendornet

# Auth — REQUIRED in production (server exits if missing when NODE_ENV=production)
JWT_SECRET=replace_with_long_random_string

# CORS — comma-separated browser origins that may call this API (exact scheme+host)
# Local:
CLIENT_ORIGINS=http://localhost:5173

# Public URLs — used for payment redirects, email links, deploy sanity checks
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# =============================================================================
# Production (Render + Vercel + MongoDB Atlas)
# =============================================================================
# Set these in Render → Environment (or in .env only on the server, never in git).
#
# NODE_ENV=production
#
# MongoDB Atlas connection string (include database name if you use one):
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/DATABASE?retryWrites=true&w=majority
#
# Strong random secret (e.g. openssl rand -hex 64):
# JWT_SECRET=...
#
# CRITICAL: Every frontend URL that loads the SPA must be listed, or browsers get CORS/network errors.
# Include your production Vercel URL AND any alternate deployment URLs, comma-separated, no spaces:
# CLIENT_ORIGINS=https://your-app.vercel.app,https://your-alias.vercel.app
#
# Must match your real public URLs (no trailing slash):
# BACKEND_URL=https://your-service.onrender.com
# FRONTEND_URL=https://your-app.vercel.app
#
# On Render, PORT is usually injected — you can omit PORT or leave it unset.

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# eSewa (v2 form + status verification) — https://developer.esewa.com.np/pages/Epay-V2
# ESEWA_MODE=sandbox
# ESEWA_PRODUCT_CODE=
# ESEWA_SECRET_KEY=
# ESEWA_SANDBOX_CHECKOUT_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
# ESEWA_PROD_CHECKOUT_URL=https://epay.esewa.com.np/api/epay/main/v2/form
# ESEWA_UAT_STATUS_URL_BASE=https://rc.esewa.com.np/api/epay/transaction/status/
# ESEWA_PROD_STATUS_URL_BASE=https://epay.esewa.com.np/api/epay/transaction/status/
# Invoice callbacks (defaults use BACKEND_URL + FRONTEND_URL if unset):
# ESEWA_SUCCESS_URL=${BACKEND_URL}/api/v1/invoice-payment/esewa/success
# ESEWA_FAILURE_URL=${BACKEND_URL}/api/v1/invoice-payment/esewa/failure
# CLIENT_ESEWA_SUCCESS_RETURN_URL=${FRONTEND_URL}/payments/esewa/success
# CLIENT_ESEWA_FAILURE_RETURN_URL=${FRONTEND_URL}/payments/esewa/failure
# Tender payment callback (path suffix /{paymentId} is appended by the app):
# ESEWA_TENDER_SUCCESS_URL=${BACKEND_URL}/api/v1/payment/esewa/callback
# ESEWA_TENDER_FAILURE_URL=${FRONTEND_URL}/my-payments?paymentStatus=cancelled

# Admin / staff dashboard cache TTL (ms)
# ADMIN_DASHBOARD_CACHE_MS=120000
# STAFF_DASHBOARD_CACHE_MS=120000

# Notification list RAM cache (ms). 0 disables
# NOTIFICATION_LIST_CACHE_MS=30000

# API_PERF_LOG=1
# API_SLOW_REQUEST_MS=2000
