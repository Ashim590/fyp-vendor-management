# App
PORT=5000
NODE_ENV=development

# Database (use a strong Atlas password; never commit real credentials)
# For low latency, prefer an Atlas region close to your API (e.g. ap-south-1 / Mumbai).
MONGO_URI=mongodb://localhost:27017/paropakar_vendornet

# Auth (required in production — see server.ts)
JWT_SECRET=replace_with_long_random_string

# CORS — comma-separated frontend origins
CLIENT_ORIGINS=http://localhost:5173

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Public URLs (preferred). Legacy SERVER_BASE_URL / CLIENT_BASE_URL still work if set.
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# eSewa (v2 form + status verification) — see https://developer.esewa.com.np/pages/Epay-V2
# Sandbox: EPAYTEST + secret 8gBm/:&EnhH.1/q (UAT). Checkout must be a form POST (opening URL in browser GET → 404).
# If POST to rc-epay still returns 404 (their sandbox sometimes down), try UAT when DNS works (often inside Nepal):
#   ESEWA_SANDBOX_CHECKOUT_URL=https://uat.esewa.com.np/api/epay/main/v2/form
#   ESEWA_UAT_STATUS_URL_BASE=https://uat.esewa.com.np/api/epay/transaction/status/
# EPAYTEST does not work on production https://epay.esewa.com.np (missing merchant key).
# ESEWA_MODE=sandbox
# ESEWA_PRODUCT_CODE=
# ESEWA_SECRET_KEY=
# Defaults: rc-epay checkout + rc.esewa status (uat.esewa.com.np often NXDOMAIN outside Nepal).
# ESEWA_UAT_CHECKOUT_URL=   (alias read if ESEWA_SANDBOX_CHECKOUT_URL unset)
# ESEWA_SANDBOX_CHECKOUT_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
# Skip sandbox POST probe before initiate: ESEWA_SKIP_CHECKOUT_PROBE=1
# Public URLs — must match what eSewa can reach (use ngrok/tunnel for local dev callbacks).
# BACKEND_URL=http://localhost:5000
# FRONTEND_URL=http://localhost:5173
# Invoice callbacks (defaults use BACKEND_URL + FRONTEND_URL if unset):
# ESEWA_SUCCESS_URL=${BACKEND_URL}/api/v1/invoice-payment/esewa/success
# ESEWA_FAILURE_URL=${BACKEND_URL}/api/v1/invoice-payment/esewa/failure
# CLIENT_ESEWA_SUCCESS_RETURN_URL=${FRONTEND_URL}/payments/esewa/success
# CLIENT_ESEWA_FAILURE_RETURN_URL=${FRONTEND_URL}/payments/esewa/failure
# Tender (award) payment — browser returns here after eSewa; must hit your API for verification.
# The app appends ?paymentId=<mongoId> (or &paymentId= if the URL already has ?).
# ESEWA_TENDER_SUCCESS_URL=${BACKEND_URL}/api/v1/payment/esewa/callback
# ESEWA_TENDER_FAILURE_URL=${FRONTEND_URL}/my-payments?paymentStatus=cancelled

# Admin / staff dashboard in-memory cache TTL (ms). Default ~120s admin, ~60s staff; max 300s capped in code.
# ADMIN_DASHBOARD_CACHE_MS=120000
# STAFF_DASHBOARD_CACHE_MS=60000
# Short TTL in-memory cache for notification list + unread count (ms). 0 disables.
# NOTIFICATION_LIST_CACHE_MS=5000
#
# Log per-request wall time (console.time) + approximate JSON body size for res.json().
# API_PERF_LOG=1
# Warn when a request exceeds this many ms (requires API_PERF_LOG for timing context in same run).
# API_SLOW_REQUEST_MS=2000
